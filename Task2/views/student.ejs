<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title><%= student.name %></title>
    <style>
        body { font-family: Arial, sans-serif; background-color: #f0f2f5; margin: 0; }
        header { background-color: #4CAF50; color: white; text-align: center; padding: 30px; font-size: 36px; font-weight: bold; }
        .container { max-width: 800px; margin: 20px auto; background: white; padding: 20px; border-radius: 10px; box-shadow: 0 0 10px rgba(0,0,0,0.1);}
        img { max-width: 200px; border-radius: 10px; display: block; margin-bottom: 15px; }
        p { line-height: 1.6; margin-bottom: 10px; }
        .nav-links a { margin-right: 15px; text-decoration: none; color: #4CAF50; font-weight: bold; }
        .nav-links a:hover { text-decoration: underline; }
        .students-list ul { list-style: none; padding: 0; }
        .students-list ul li { margin: 5px 0; }
        .students-list ul li a { color: #4CAF50; font-weight: bold; text-decoration: none; }
        .students-list ul li a:hover { text-decoration: underline; }
    </style>
</head>
<body>
<header>Інформація про студента</header>

<div class="container">
    <div class="nav-links">
        <a href="/">Повернутися до головної</a>
        <a href="/students">Повернутися до студентів</a>
    </div>

    <h2><%= student.name %></h2>
    <img src="<%= student.photo %>" alt="Фото <%= student.name %>">
    <p><strong>Вік:</strong> <%= student.age %></p>
    <p><strong>Група:</strong> <%= student.group %></p>
    <p><strong>Університет:</strong> <%= student.university %></p>
    <p><strong>Факультет:</strong> <%= student.faculty %></p>
    <p><strong>Курси:</strong> <%= student.courses.join(', ') %></p>
    <p><strong>Хобі:</strong> <%= student.hobby %></p>
    <p><%= student.description %></p>

    <div class="students-list">
        <h3>Наші студенти</h3>
        <ul>
            <% students.forEach(s => { %>
                <li>
                    <a href="/student/<%= s.name.toLowerCase().replace(/[^a-zа-я0-9]/g, '') %>">
                        <%= s.name %>
                    </a>
                </li>
            <% }) %>
        </ul>
        <a href="/">Повернутися до головної</a>
    </div>
</div>
</body>
</html>