<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title><%= student.name %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/header') %>

    <div class="container">
        <h2><%= student.name %></h2>
        <img src="<%= student.photo %>" alt="<%= student.name %>" class="student-photo">
        
        <p><strong>Вік:</strong> <%= student.age %></p>
        <p><strong>Група:</strong> <%= student.group %></p>
        <p><strong>Університет:</strong> <%= student.university %></p>
        <p><strong>Хобі:</strong> <%= student.hobby %></p>
        <p><strong>Курси:</strong> <%= student.courses.join(', ') %></p>
        
        <div class="kpi-box">
            <%= student.description %>
        </div>

        <hr>
        <a href="/students">← Повернутися до списку</a>
    </div>
</body>
</html>